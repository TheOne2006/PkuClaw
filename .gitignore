# PkuClaw Gitignore

# 用户数据（自动生成的课程文件夹）
*/
!/.gitignore
!/LICENSE
!/README.md
!/skill.md
!/pyproject.toml
!/configs/
!/configs/**/
!/configs/**/*
!/pkuclaw/
!/pkuclaw/**/
!/pkuclaw/**/*
!/scripts/
!/scripts/**/
!/scripts/**/*
!/sub-skills/
!/sub-skills/**/
!/sub-skills/**/*
!/codex/
!/codex/**/
!/codex/**/*
!/images
!/crates/
!/crates/**/
!/crates/**/*
crates/*/target/
archive/
# docs/ 在 main 分支被忽略，文档网站托管在独立的 docs 分支
docs/
# 汇总报告（自动生成）
通知摘要汇总.md

# Local secrets and runtime state
.env
.env.*
!.env.example
data/
logs/
tmp/

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
