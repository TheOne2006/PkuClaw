{
  "schema_version": 1,
  "agent": {
    "provider": "codex",
    "mode": "fixed",
    "model": "gpt-5.5",
    "reasoning_effort": "xhigh"
  },
  "codex": {
    "sandbox": "workspace-write",
    "timeout_seconds": 1800
  },
  "loops": [
    {
      "id": "sync_notices",
      "enabled": true,
      "interval_seconds": 1800,
      "prompt": "增量检查 PKU 教学网课程通知、作业、DDL、公告和本地快照。优先比较 data/pkuclaw/course-sync 下的上次快照；没有重要变化则只更新本地摘要并保持静默。发现新增/变更 DDL、即将到期/逾期作业、重要公告、登录失效或工具缺失等需要用户知道的情况时，使用 Notification Script Skill 中的文件队列脚本发送简洁通知。不要提交作业，不要下载大附件，缺少凭据或需要交互登录时说明需要用户处理。",
      "skill_names": [
        "tasks/sync-notices.md"
      ],
      "sink_mode": "silent",
      "prevent_overlap": true,
      "max_concurrent_runs": 1
    }
  ],
  "notifications": {
    "policy": "important_only",
    "default_channel": "feishu",
    "default_target_type": "open_id",
    "default_target_id": "ou_7ca740787ca9699e75abcc3d8435ae5d"
  }
}
